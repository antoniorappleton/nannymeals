rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Recipes are public
    match /recipes/{recipeId} {
      allow read: if true;
      allow write: if false;
    }

    // Households: access by owner
    match /households/{hid} {
      allow create: if request.auth != null;
      allow read, write: if request.auth != null && 
        (resource == null || resource.data.ownerUid == request.auth.uid);
    }

    // Weekly plans: access if you belong to the household
    match /weeklyPlans/{planId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && 
        (resource == null || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.householdId == resource.data.householdId);
      allow delete: if false;
    }

    // Feedback
    match /feedback/{fid} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && resource.data.ownerUid == request.auth.uid;
    }

    // User profiles: strictly personal
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
