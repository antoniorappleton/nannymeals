rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // recipes: global collection maintained by the administrator only
    match /recipes/{recipeId} {
      allow read: if request.auth != null;                        // anybody logged in can read
      allow write: if request.auth.token.email == "antonioappleton@gmail.com"; // only admin can modify
    }

    // userRecipes: each document belongs to a user and stores a reference
    // to a global recipe plus any custom fields the user applied.
    match /userRecipes/{docId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Households: access by owner
    match /households/{hid} {
      allow create: if request.auth != null;
      allow read, write: if request.auth != null && 
        (resource == null || resource.data.ownerUid == request.auth.uid);
    }

    // Weekly plans: each document belongs to a household
    match /weeklyPlans/{planId} {
      allow create: if request.auth != null; // creation performed by client or functions
      allow read, update: if request.auth != null &&
                          (resource.data.householdId == request.auth.uid ||
                           // allow if the user is owner of household document
                           exists(/databases/$(database)/documents/households/$(request.auth.uid)) &&
                           get(/databases/$(database)/documents/households/$(request.auth.uid)).data.ownerUid == request.auth.uid);
      // deletion from client is disallowed; cleanup function will remove expired
      allow delete: if false;
    }

    // Feedback
    match /feedback/{fid} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && resource.data.ownerUid == request.auth.uid;
    }

    // User profiles: strictly personal
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
